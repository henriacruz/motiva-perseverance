    {
        "id": "6ba5c4156a1e57bb",
        "type": "function",
        "z": "flow_mock",
        "name": "Capt Chat ID",
        "func": "var chatId = msg.payload.chatId;\nvar chatType = msg.payload.chat?.type || \"private\";\nvar chatTitle = msg.payload.chat?.title || \"N/A\";\nvar username = msg.payload.from?.username || \"sem_username\";\nvar firstName = msg.payload.from?.first_name || \"Usuário\";\n\nnode.warn(\"??????????????????????????????\");\nnode.warn(\"?? Novo contato: \" + chatId);\nnode.warn(\"Tipo: \" + chatType);\n\nif (chatType === \"group\" || chatType === \"supergroup\") {\n    node.warn(\"Nome do Grupo: \" + chatTitle);\n    node.warn(\"?? Este é um GRUPO - use este ID!\");\n    global.set(\"groupChatId\", chatId);\n    \n    msg.payload = {\n        chatId: chatId,\n        type: \"message\",\n        content: \"? *Grupo Registrado com Sucesso!*\\n\\n\" +\n                 \"?? Nome: \" + chatTitle + \"\\n\" +\n                 \"?? Chat ID: `\" + chatId + \"`\\n\\n\" +\n                 \"?? Todos os membros receberão notificações automáticas quando houver mudança no status do Motiva Perseverance!\\n\\n\" +\n                 \"?? Use os comandos para interagir com o bot.\",\n        parse_mode: \"Markdown\"\n    };\n} else {\n    node.warn(\"Username: @\" + username);\n    node.warn(\"Nome: \" + firstName);\n    node.warn(\"?? Este é um chat INDIVIDUAL\");\n    \n    var chatIds = global.get(\"chatIds\") || [];\n    \n    if (chatIds.includes(chatId)) {\n        node.warn(\"?? Usuário Já registrado - SEM mensagem!\");\n        node.warn(\"??????????????????????????????\");\n        return null;\n    }\n    \n    chatIds.push(chatId);\n    global.set(\"chatIds\", chatIds);\n    \n    node.warn(\"? Usuário adicionado à lista!\");\n    node.warn(\"?? Total de usuàrios registrados: \" + chatIds.length);\n    \n    msg.payload = {\n        chatId: chatId,\n        type: \"message\",\n        content: \"? *Registrado com Sucesso!*\\n\\n\" +\n                 \"?? Nome: \" + firstName + \"\\n\" +\n                 \"?? Seu Chat ID: `\" + chatId + \"`\\n\\n\" +\n                 \"?? Você receberá notificações automáticas sempre que:\\n\" +\n                 \". Status mudar de SEGURO ? ATENÇÃO\\n\" +\n                 \". Status mudar de ATENÇÃO ? PERIGO\\n\" +\n                 \". Status mudar de PERIGO ? SEGURO\\n\\n\" +\n                 \"?? Use os comandos abaixo para interagir!\",\n        parse_mode: \"Markdown\"\n    };\n}\n\nnode.warn(\"??????????????????????????????\");\nreturn msg;",
