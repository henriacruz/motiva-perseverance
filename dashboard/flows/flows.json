        "id": "fn_status",
        "type": "function",
        "z": "flow_mock",
        "name": "Mock Status",
        "func": "var modes = ['MANUAL', 'SEMI-AUTO'];\nvar alertas = [\n    'Nenhum alerta',\n    'Nenhum alerta',\n    'Nenhum alerta',\n    'Bateria baixa!',\n    'Obstáculo frontal < 30 cm'\n];\nmsg.payload = {\n    mode: modes[Math.round(Math.random())],\n    battery: Math.round(Math.random() * 60 + 40),\n    alert: alertas[Math.floor(Math.random() * alertas.length)]\n};\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 430,
        "y": 840,
