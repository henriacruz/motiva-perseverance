    {
        "id": "fn_telem",
        "type": "function",
        "z": "flow_mock",
        "name": "Mock Telemetria",
        "func": "function rand(min, max) { return Math.random() * (max - min) + min; }\n\n// Rodovia Anhanguera SP-330 — segmento ~km 70 (Jundiaí), bearing ~310°\nvar route = [[-23.215,-46.87],[-23.2147,-46.8704],[-23.2143,-46.8709],[-23.214,-46.8713],[-23.2136,-46.8718],[-23.2133,-46.8722],[-23.2129,-46.8727],[-23.2126,-46.8731],[-23.2122,-46.8736],[-23.2119,-46.874],[-23.2115,-46.8745],[-23.2112,-46.8749],[-23.2108,-46.8754],[-23.2105,-46.8758],[-23.2101,-46.8763],[-23.2098,-46.8767],[-23.2094,-46.8772],[-23.2091,-46.8776],[-23.2087,-46.8781],[-23.2084,-46.8785],[-23.208,-46.879],[-23.2077,-46.8794],[-23.2073,-46.8799],[-23.207,-46.8803],[-23.2066,-46.8808],[-23.2063,-46.8812],[-23.2059,-46.8817],[-23.2056,-46.8821],[-23.2052,-46.8826],[-23.2049,-46.883],[-23.2045,-46.8835],[-23.2042,-46.8839],[-23.2038,-46.8844],[-23.2035,-46.8848],[-23.2031,-46.8853],[-23.2028,-46.8857],[-23.2024,-46.8862],[-23.2021,-46.8866],[-23.2017,-46.8871],[-23.2014,-46.8875]];\n\nvar idx = flow.get('routeIdx') || 0;\nvar pt  = route[idx];\nflow.set('routeIdx', (idx + 1) % route.length);\n\nvar v = parseFloat(rand(11.1, 12.6).toFixed(2));\nvar i = parseFloat(rand(0.5, 7.5).toFixed(3));\nmsg.payload = {\n    lat:     parseFloat((pt[0] + rand(-0.00003, 0.00003)).toFixed(6)),\n    lon:     parseFloat((pt[1] + rand(-0.00003, 0.00003)).toFixed(6)),\n    roll:    parseFloat(rand(-4, 4).toFixed(2)),\n    pitch:   parseFloat(rand(-2, 2).toFixed(2)),\n    yaw:     parseFloat((310 + rand(-5, 5)).toFixed(1)),\n    d_front: Math.max(10, Math.round(rand(80, 400))),\n    d_rear:  Math.max(10, Math.round(rand(80, 400))),\n    d_left:  Math.max(5,  Math.round(rand(15, 60))),\n    d_right: Math.max(5,  Math.round(rand(15, 60))),\n    voltage: v,\n    current: i,\n    power:   parseFloat((v * i).toFixed(2))\n};\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 430,
        "y": 340,
        "wires": [
            [
                "mqtt_out_telem"
            ]
        ]
    },
