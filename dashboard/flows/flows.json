        "func": "var chatId = msg.payload.chatId;\n\nmsg.payload = {\n    chatId: chatId,\n    type: \"message\",\n    content: `?? *Monitor Perseverance - Bot de Alertas*\\n\\n` +\n             `*Comandos Disponíveis:*\\n\\n` +\n             `/Ajuda - Mostra esta mensagem\\n` +\n             `/Dados - Última medição dos sensores\\n` +\n             `/Display - Estatísticas completas\\n` +\n             `/Status - Status do sistema\\n\\n` +\n             `?? *Sistema de Alertas:*\\n` +\n             `Você receberá notificaçõe automáticas sempre que:\\n` +\n             `. Status mudar de SEGURO ? ATENÇÃO\\n` +\n             `. Status mudar de ATENÇÃO ? PERIGO\\n` +\n             `. Status mudar de PERIGO ? SEGURO\\n\\n` +\n             `?? *Dica:* Use os comandos a qualquer momento!`,\n    parse_mode: \"Markdown\"\n};\n\nreturn msg;",
